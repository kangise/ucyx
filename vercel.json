{
  "redirects": [
    {
      "source": "/market-entry-services.html",
      "destination": "/services",
      "permanent": true
    },
    {
      "source": "/company-profile.html",
      "destination": "/company",
      "permanent": true
    },
    {
      "source": "/faq.html",
      "destination": "/#faq",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ]
}
